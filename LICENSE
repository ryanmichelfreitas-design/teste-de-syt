        </div>
        <div class="nav-badge">
            <span>➕</span> <span>➖</span> <span>✖️</span> <span>➗</span> <span>🧩</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="hero">
        <div class="hero-text">
            <h2>📚 Aprender é Brincar!</h2>
            <p>Clique nos desafios e pratique adição, subtração, multiplicação, divisão e muito mais. Cada ano tem perguntas especiais! 🎯</p>
        </div>
        <div class="hero-emoji">
            🧮✨
        </div>
    </div>

    <!-- seletor de anos -->
    <div class="grade-ano" id="anoSelector">
        <div data-ano="3" class="ano-card ativo">🐣 3º Ano</div>
        <div data-ano="4" class="ano-card">🐱 4º Ano</div>
        <div data-ano="5" class="ano-card">🦊 5º Ano</div>
    </div>

    <!-- cards dinâmicos -->
    <div class="conteudo-principal">
        <h2 style="font-size: 1.9rem; text-align: center;">🌟 Desafios Matemáticos 🌟</h2>
        <div id="cardsContainer" class="cards-grid">
            <!-- preenchido por js -->
        </div>
    </div>
</div>

<div class="footer">
    <p>🎓 Matemática divertida - 3º, 4º e 5º ano do Ensino Fundamental | Resolva os desafios e aprenda brincando 🎓</p>
    <p style="margin-top: 8px;">✨ Cada acerto te deixa mais inteligente! ✨</p>
</div>

<!-- Modal do quiz -->
<div id="quizModal" class="modal">
    <div class="modal-content">
        <div class="close-modal" id="closeModalBtn">&times;</div>
        <div id="modalIcon" style="font-size: 3rem;">🧠</div>
        <div id="modalTitle" class="pergunta" style="font-size: 1.5rem; background: #ffe2c4;">Carregando...</div>
        <div id="questionText" style="font-size: 1.7rem; font-weight: bold; margin: 15px 0;">?</div>
        <div id="optionsArea" class="opcoes"></div>
        <div id="feedbackMsg" class="feedback"></div>
        <button id="nextQuizBtn" class="next-btn">✨ Próxima pergunta ✨</button>
    </div>
</div>

<script>
    // ---------- Banco de questões por ano e por categoria ----------
    // Cada questão: texto, opções (array), respostaCorreta (string ou número), dica (opcional)
    const questoesPorAno = {
        3: [
            { titulo: "➕ Adição divertida", pergunta: "29 + 14 = ?", opcoes: ["43", "42", "44", "33"], resposta: "43" },
            { titulo: "➖ Subtraindo brinquedos", pergunta: "57 - 23 = ?", opcoes: ["34", "35", "33", "30"], resposta: "34" },
            { titulo: "✖️ Introdução à multiplicação", pergunta: "4 × 3 = ?", opcoes: ["12", "9", "16", "7"], resposta: "12" },
            { titulo: "🧸 Sequência numérica", pergunta: "Qual é o próximo número? 15, 20, 25, ___", opcoes: ["30", "35", "28", "26"], resposta: "30" },
            { titulo: "🍎 Dobro e metade", pergunta: "Qual é o dobro de 8?", opcoes: ["16", "14", "18", "12"], resposta: "16" }
        ],
        4: [
            { titulo: "➕ Adição com reserva", pergunta: "268 + 179 = ?", opcoes: ["447", "437", "457", "467"], resposta: "447" },
            { titulo: "✖️ Tabuada essencial", pergunta: "7 × 8 = ?", opcoes: ["56", "48", "64", "54"], resposta: "56" },
            { titulo: "➖ Subtração com empréstimo", pergunta: "400 - 158 = ?", opcoes: ["242", "252", "248", "258"], resposta: "242" },
            { titulo: "📏 Problema com medidas", pergunta: "Um lápis tem 15 cm. Quantos centímetros têm 4 lápis juntos?", opcoes: ["60 cm", "55 cm", "45 cm", "70 cm"], resposta: "60 cm" },
            { titulo: "🧩 Divisão simples", pergunta: "36 ÷ 4 = ?", opcoes: ["9", "8", "7", "6"], resposta: "9" }
        ],
        5: [
            { titulo: "✖️ Multiplicação maior", pergunta: "24 × 12 = ?", opcoes: ["288", "268", "278", "298"], resposta: "288" },
            { titulo: "➗ Divisão com resto", pergunta: "85 ÷ 6 = ?", opcoes: ["14 resto 1", "13 resto 7", "14 resto 2", "13 resto 2"], resposta: "14 resto 1" },
            { titulo: "🧮 Frações simples", pergunta: "Quanto é 1/4 de 100?", opcoes: ["25", "20", "30", "15"], resposta: "25" },
            { titulo: "📊 Porcentagem inicial", pergunta: "10% de 90 reais é igual a:", opcoes: ["9 reais", "8 reais", "10 reais", "12 reais"], resposta: "9 reais" },
            { titulo: "⚖️ Expressão numérica", pergunta: "(15 + 5) × 2 = ?", opcoes: ["40", "35", "30", "45"], resposta: "40" }
        ]
    };

    // Categorias/temas interativos extras (mostrados nos cards) para cada ano 
    // além do quiz, teremos cards divertidos que abrem perguntas correspondentes. 
    // Vamos mapear títulos legais baseados nas questões.

    function getCardsByAno(ano) {
        const questoes = questoesPorAno[ano] || questoesPorAno[3];
        // Criar 4 ou 5 cards com base nas questões disponíveis 
        return questoes.map((q, idx) => ({
            id: idx,
            titulo: q.titulo,
            descricao: `Pratique ${q.titulo.toLowerCase()} com um desafio incrível!`,
            emoji: getEmojiPorTitulo(q.titulo),
            questaoRef: q
        }));
    }

    function getEmojiPorTitulo(titulo) {
        if (titulo.includes("Adição")) return "➕";
        if (titulo.includes("Subtração")) return "➖";
        if (titulo.includes("Multiplicação") || titulo.includes("Tabuada")) return "✖️";
        if (titulo.includes("Divisão")) return "➗";
        if (titulo.includes("Sequência")) return "🔢";
        if (titulo.includes("Dobro")) return "🍎";
        if (titulo.includes("Problema")) return "📏";
        if (titulo.includes("Frações")) return "🧮";
        if (titulo.includes("Porcentagem")) return "💯";
        if (titulo.includes("Expressão")) return "⚖️";
        return "🧠";
    }

    let currentAno = 3;
    let currentQuestionIndex = 0;
    let currentQuestionsList = []; // armazena as questões do ano ativo
    let currentQuizQuestion = null; // objeto da questão atual no modal

    // elementos DOM
    const anoSelectorDiv = document.getElementById('anoSelector');
    const cardsContainer = document.getElementById('cardsContainer');
    const modal = document.getElementById('quizModal');
    const modalTitle = document.getElementById('modalTitle');
    const questionText = document.getElementById('questionText');
    const optionsArea = document.getElementById('optionsArea');
    const feedbackMsg = document.getElementById('feedbackMsg');
    const nextQuizBtn = document.getElementById('nextQuizBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const modalIcon = document.getElementById('modalIcon');

    // renderizar cards conforme ano atual
    function renderCards() {
        const cardsData = getCardsByAno(currentAno);
        cardsContainer.innerHTML = '';
        cardsData.forEach(card => {
            const cardDiv = document.createElement('div');
            cardDiv.className = 'card-atividade';
            cardDiv.innerHTML = `
                <div class="emoji-materia">${card.emoji}</div>
                <h3>${card.titulo}</h3>
                <div class="descricao">${card.descricao}</div>
                <button class="btn-desafio" data-idx="${card.id}">🎲 Tentar desafio →</button>
            `;
            cardsContainer.appendChild(cardDiv);
        });

        // adicionar eventos nos botões dos cards
        document.querySelectorAll('.btn-desafio').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const idx = parseInt(btn.getAttribute('data-idx'));
                const cardsDataLocal = getCardsByAno(currentAno);
                if (cardsDataLocal[idx]) {
                    const questaoObj = cardsDataLocal[idx].questaoRef;
                    openQuizWithQuestion(questaoObj);
                }
            });
        });
    }

    // atualiza o ano ativo visual e os cards
    function setAno(ano) {
        currentAno = ano;
        // atualizar classe ativa nos botões
        document.querySelectorAll('.ano-card').forEach(el => {
            const anoVal = parseInt(el.getAttribute('data-ano'));
            if (anoVal === ano) {
                el.classList.add('ativo');
            } else {
                el.classList.remove('ativo');
            }
        });
        renderCards();
    }

    // abre modal com uma questão específica
    function openQuizWithQuestion(question) {
        currentQuizQuestion = { ...question };
        modalTitle.innerText = currentQuizQuestion.titulo;
        questionText.innerText = currentQuizQuestion.pergunta;
        // gerar opções
        optionsArea.innerHTML = '';
        currentQuizQuestion.opcoes.forEach(op => {
            const opcaoDiv = document.createElement('div');
            opcaoDiv.className = 'opcao';
            opcaoDiv.innerText = op;
            opcaoDiv.addEventListener('click', () => {
                checkAnswer(op, currentQuizQuestion.resposta);
            });
            optionsArea.appendChild(opcaoDiv);
        });
        feedbackMsg.innerHTML = '';
        feedbackMsg.className = 'feedback';
        modalIcon.innerText = getEmojiPorTitulo(currentQuizQuestion.titulo);
        modal.style.display = 'flex';
    }

    function checkAnswer(selected, correctAnswer) {
        // comparação normalizada (string)
        let selecionadoStr = selected.toString().trim();
        let corretoStr = correctAnswer.toString().trim();
        let isCorrect = (selecionadoStr === corretoStr);
        if (isCorrect) {
            feedbackMsg.innerHTML = '🎉 Muito bem! Resposta correta! 🎉';
            feedbackMsg.className = 'feedback certo';
            // opcional: animação
        } else {
            feedbackMsg.innerHTML = `❌ Ops! Resposta errada. A resposta correta é: ${corretoStr}. Tente de novo! 🌟`;
            feedbackMsg.className = 'feedback errado';
        }
        // desabilitar clique nas opções para não múltiplas respostas?
        const allOpts = document.querySelectorAll('.opcao');
        allOpts.forEach(opt => {
            opt.style.pointerEvents = 'none';
            opt.style.opacity = '0.6';
        });
        // mostrar botão próximo
        nextQuizBtn.style.display = 'inline-block';
    }

    function loadNextRandomQuestion() {
        // carrega uma nova questão do mesmo ano (diferente da atual se possível, mas pode repetir, mas é legal)
        const questoes = questoesPorAno[currentAno];
        if (!questoes || questoes.length === 0) return;
        let newIndex = Math.floor(Math.random() * questoes.length);
        // evitar mesma questão sucessiva se houver mais de 1
        if (questoes.length > 1 && currentQuizQuestion && questoes[newIndex].pergunta === currentQuizQuestion.pergunta) {
            newIndex = (newIndex + 1) % questoes.length;
        }
        const novaQuestao = { ...questoes[newIndex] };
        // resetar modal
        currentQuizQuestion = novaQuestao;
        modalTitle.innerText = currentQuizQuestion.titulo;
        questionText.innerText = currentQuizQuestion.pergunta;
        optionsArea.innerHTML = '';
        currentQuizQuestion.opcoes.forEach(op => {
            const opcaoDiv = document.createElement('div');
            opcaoDiv.className = 'opcao';
            opcaoDiv.innerText = op;
            opcaoDiv.addEventListener('click', () => {
                checkAnswer(op, currentQuizQuestion.resposta);
            });
            optionsArea.appendChild(opcaoDiv);
        });
        feedbackMsg.innerHTML = '';
        feedbackMsg.className = 'feedback';
        modalIcon.innerText = getEmojiPorTitulo(currentQuizQuestion.titulo);
        // reabilitar opções
        const allOpts = document.querySelectorAll('.opcao');
        allOpts.forEach(opt => {
            opt.style.pointerEvents = 'auto';
            opt.style.opacity = '1';
        });
        nextQuizBtn.style.display = 'inline-block';
        // mas não queremos que o botão "próximo" acumule eventos; já tratamos.
    }

    // evento do botão próximo:  carrega outra pergunta do mesmo ano
    nextQuizBtn.addEventListener('click', () => {
        loadNextRandomQuestion();
    });

    // fechar modal
    function closeModal() {
        modal.style.display = 'none';
        // reset feedback e reabilitar cliques caso reabra
        feedbackMsg.innerHTML = '';
        const allOpts = document.querySelectorAll('.opcao');
        allOpts.forEach(opt => {
            opt.style.pointerEvents = 'auto';
            opt.style.opacity = '1';
        });
    }

    closeModalBtn.addEventListener('click', closeModal);
    window.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // evento de seleção de ano
    anoSelectorDiv.querySelectorAll('.ano-card').forEach(card => {
        card.addEventListener('click', (e) => {
            const ano = parseInt(card.getAttribute('data-ano'));
            if (!isNaN(ano)) {
                setAno(ano);
            }
        });
    });

    // Inicialização
    setAno(3);

    // Pequeno ajuste: garantir que ao abrir modal por card, as opções tenham eventos únicos e que o botão próximo carregue novas
    // função auxiliar para quando for aberto via card (já foi implementada openQuizWithQuestion)
    // também precisamos garantir que o nextQuizBtn funcione sempre com o ano atual
    // e não conflitar com a questão atual -> o loadNextRandomQuestion usa o currentAno global
    // e também atualiza o currentQuizQuestion.
    // Para evitar problemas de ponteiro duplicado, removemos listeners antigos do botão? Não, já temos um único.
    // Tudo ok.

    // bônus: As questões podem ter textos longos, mas estão adequadas para faixa etária.
    console.log("Site Matemágica carregado com sucesso!");
</script>
</body>
</html>.