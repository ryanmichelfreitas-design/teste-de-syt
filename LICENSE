        .btn-desafio {
            background: #FFD966;
            border: none;
            padding: 12px 22px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            color: #5a2e0e;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }

        .btn-desafio:hover {
            background: #ffc107;
            transform: scale(0.97);
            box-shadow: 0 3px 8px rgba(0,0,0,0.1);
        }

        /* modal interativo */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.6);
            backdrop-filter: blur(5px);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-content {
            background: #FFFCF5;
            max-width: 550px;
            width: 90%;
            border-radius: 64px;
